# 4PRO Identity Service - Environment Variables

# Owner connection (for migrations only)
DATABASE_OWNER_URL="postgresql://neondb_owner:<PASSWORD>@<HOST>:5432/identity_service_db?sslmode=require"

# Service connection (restricted user - for application use)
IDENTITY_DB_URL="postgresql://identity_service_user:<PASSWORD>@<HOST>:5432/identity_service_db?sslmode=require"

# JWT secret for signing SSO tokens
JWT_SECRET="change-me-to-a-strong-random-secret"

# Cookie domain for SSO (localhost for dev, .4pro.io for prod)
COOKIE_DOMAIN="localhost"
COOKIE_SECURE=false
COOKIE_SAMESITE="Lax"

# Server port
IDENTITY_PORT=4100
